{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/IBM/simrun/simrun.schema.json",
  "title": "Simrun Test Suite",
  "description": "Schema for a Simrun test suite",
  "type": "object",
  "required": [
    "scenarios"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Metadata information for the scenarios set",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the scenarios set"
        },
        "description": {
          "type": "string",
          "description": "Description of the scenarios set"
        }
      }
    },
    "targets": {
      "type": "object",
      "description": "Connector targets for all scenarios in this file. Keys are connector types (aws, gcp, azure, kubernetes, ssh), values are connector names.",
      "properties": {
        "aws": {
          "type": "string",
          "description": "Name of the AWS connector to use for cloud credentials"
        },
        "gcp": {
          "type": "string",
          "description": "Name of the GCP connector to use for cloud credentials"
        },
        "azure": {
          "type": "string",
          "description": "Name of the Azure connector to use for cloud credentials"
        },
        "kubernetes": {
          "type": "string",
          "description": "Name of the Kubernetes connector to use for cluster access"
        },
        "ssh": {
          "type": "string",
          "description": "Name of the SSH connector to use for remote command detonation"
        }
      },
      "additionalProperties": false
    },
    "scenarios": {
      "description": "The display name of the vulnerability",
      "type": "array",
      "items": {
        "type": "object",
        "description": "The list of scenarios",
"required": [
          "name",
          "expectations"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Description of the scenario"
          },
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether this scenario is enabled. Disabled scenarios are skipped during execution."
          },
          "indicators": {
            "type": "object",
            "description": "Indicators to be extracted from the scenario",
            "properties": {
              "terraformOutput": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of Terraform output keys to extract"
              },
              "static": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of static indicator values"
              }
            }
          },
          "detonate": {
            "type": "object",
            "description": "How to detonate the attack",
            "oneOf": [
              {
                "required": [
                  "awsCliDetonator"
                ]
              },
              {
                "required": [
                  "simrunDetonator"
                ]
              }
            ],
            "properties": {
              "awsCliDetonator": {
                "$ref": "awsCliDetonator.schema.json"
              },
              "simrunDetonator": {
                "$ref": "simrunDetonator.schema.json"
              }
            }
          },
          "inject": {
            "type": "object",
            "description": "How to inject data for testing detections",
            "oneOf": [
              {
                "required": [
                  "elasticInjector"
                ]
              }
            ],
            "properties": {
              "elasticInjector": {
                "$ref": "elasticInjector.schema.json"
              }
            }
          },
          "collect": {
            "type": "object",
            "description": "How to collect logs produced by the attack activity",
            "oneOf": [
              {
                "required": [
                  "elasticCollector"
                ]
              }
            ],
            "properties": {
              "elasticCollector": {
                "$ref": "elasticCollector.schema.json"
              }
            }
          },
          "expectations": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Expectations",
              "oneOf": [
                {
                  "required": [
                    "datadogSecuritySignal"
                  ]
                },
                {
                  "required": [
                    "elasticSecurityAlert"
                  ]
                }
              ],
              "properties": {
                "datadogSecuritySignal": {
                  "$ref": "datadogSecuritySignal.schema.json"
                },
                "elasticSecurityAlert": {
                  "$ref": "elasticSecurityAlert.schema.json"
                },
                "timeout": {
                  "type": "string",
                  "default": "5m",
                  "description": "The maximal time to wait for the assertion, written as a Go duration (e.g. 5m)"
                }
              }
            }
          }
        }
      }
    }
  }
}